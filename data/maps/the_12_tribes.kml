<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>The 12 Tribes Allotments</name>
    <description>Territorial divisions of the tribes of Israel after the conquest of Canaan.</description>
    
    <!-- Tribal Area Styles -->
    <Style id="judahStyle">
      <LineStyle><color>ff0000ff</color><width>2</width></LineStyle>
      <PolyStyle><color>400000ff</color></PolyStyle> <!-- Translucent Red -->
    </Style>
    <Style id="ephraimStyle">
      <LineStyle><color>ff00ff00</color><width>2</width></LineStyle>
      <PolyStyle><color>4000ff00</color></PolyStyle> <!-- Translucent Green -->
    </Style>
    <Style id="galileeTribes">
      <LineStyle><color>ffff0000</color><width>2</width></LineStyle>
      <PolyStyle><color>40ffff00</color></PolyStyle> <!-- Translucent Cyan -->
    </Style>
    <Style id="transjordanStyle">
      <LineStyle><color>ff00ffff</color><width>2</width></LineStyle>
      <PolyStyle><color>4000ffff</color></PolyStyle> <!-- Translucent Yellow -->
    </Style>

    <!-- Southern Sector: Judah & Simeon -->
    <Folder>
      <name>Southern Tribes (Judah and Simeon)</name>
      <Placemark>
        <name>Judah Territory</name>
        <description>Joshua 15 - The massive southern wilderness, hill country, and Dead Sea border.</description>
        <styleUrl>#judahStyle</styleUrl>
        <Polygon>
          <outerBoundaryIs>
            <LinearRing>
              <coordinates>
                34.2518,31.2518,0
                35.2137,31.4000,0
                35.4000,31.2000,0
                35.4800,31.8000,0
                35.0000,31.8500,0
                34.5000,31.5000,0
                34.2518,31.2518,0
              </coordinates>
            </LinearRing>
          </outerBoundaryIs>
        </Polygon>
      </Placemark>
    </Folder>

    <!-- Central Sector: Ephraim, Manasseh, Benjamin, Dan -->
    <Folder>
      <name>Central Tribes (Ephraim and West Manasseh)</name>
      <Placemark>
        <name>Ephraim and Central Allotments</name>
        <description>Joshua 16 - Heart of the central hill country containing Shiloh and Shechem.</description>
        <styleUrl>#ephraimStyle</styleUrl>
        <Polygon>
          <outerBoundaryIs>
            <LinearRing>
              <coordinates>
                34.8000,31.9000,0
                35.5000,31.9000,0
                35.5500,32.4000,0
                34.9000,32.4500,0
                34.8000,31.9000,0
              </coordinates>
            </LinearRing>
          </outerBoundaryIs>
        </Polygon>
      </Placemark>
    </Folder>

    <!-- Northern Sector: Asher, Naphtali, Zebulun, Issachar -->
    <Folder>
      <name>Northern Tribes (Galilee Cluster)</name>
      <Placemark>
        <name>Galilee Tribes (Naphtali/Asher/Zebulun)</name>
        <description>Joshua 19 - Northern frontiers bordering Phoenicia and the Sea of Galilee.</description>
        <styleUrl>#galileeTribes</styleUrl>
        <Polygon>
          <outerBoundaryIs>
            <LinearRing>
              <coordinates>
                34.9500,32.5000,0
                35.6500,32.5000,0
                35.6521,33.2486,0
                35.1000,33.1000,0
                34.9500,32.5000,0
              </coordinates>
            </LinearRing>
          </outerBoundaryIs>
        </Polygon>
      </Placemark>
    </Folder>

    <!-- Eastern Sector: Reuben, Gad, East Manasseh -->
    <Folder>
      <name>Transjordan Tribes (Reuben, Gad, East Manasseh)</name>
      <Placemark>
        <name>Transjordan Allotments</name>
        <description>Joshua 13 - Lands assigned by Moses east of the Jordan River.</description>
        <styleUrl>#transjordanStyle</styleUrl>
        <Polygon>
          <outerBoundaryIs>
            <LinearRing>
              <coordinates>
                35.5500,31.3000,0
                36.2000,31.3000,0
                36.0000,33.2000,0
                35.6200,32.8000,0
                35.5500,31.3000,0
              </coordinates>
            </LinearRing>
          </outerBoundaryIs>
        </Polygon>
      </Placemark>
    </Folder>
  </Document>
</kml>
